{
  "controller_type": "knuckles",
  "description": "Ravenfield VR default bindings for Valve Index controllers",
  "bindings": {
    "/actions/default": {
      "sources": [
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/default/in/Trigger" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/default/in/Trigger" }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/default/in/Grip" }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/default/in/Grip" }
          }
        },
        {
          "path": "/user/hand/left/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/default/in/Stick" },
            "click": { "output": "/actions/default/in/StickClick" }
          }
        },
        {
          "path": "/user/hand/right/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/default/in/Stick" },
            "click": { "output": "/actions/default/in/StickClick" }
          }
        },
        {
          "path": "/user/hand/left/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/default/in/ButtonA" }
          }
        },
        {
          "path": "/user/hand/right/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/default/in/ButtonA" }
          }
        },
        {
          "path": "/user/hand/left/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/default/in/ButtonB" }
          }
        },
        {
          "path": "/user/hand/right/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/default/in/ButtonB" }
          }
        }
      ],
      "haptics": [
        {
          "path": "/user/hand/left/output/haptic",
          "output": "/actions/default/out/Haptic"
        },
        {
          "path": "/user/hand/right/output/haptic",
          "output": "/actions/default/out/Haptic"
        }
      ]
    }
  }
}
